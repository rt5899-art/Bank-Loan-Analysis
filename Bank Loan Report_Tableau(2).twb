      <aliases enabled='yes' />
      <column caption='Total Loan Application' datatype='integer' name='[Calculation_183803219454484480]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([id])' />
      </column>
      <column caption='MTD Loan Application' datatype='integer' name='[Calculation_183803219458863108]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF &#13;&#10;DATEDIFF(&apos;month&apos;,[issue_date], {MAX([issue_date])})=0&#13;&#10;THEN&#13;&#10;[id]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='PMTD Loan Application' datatype='integer' name='[Calculation_183803219461976080]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF  &#13;&#10;DATEDIFF(&apos;month&apos;,[issue_date],{MAX([issue_date])})=1&#13;&#10;THEN&#13;&#10;[id]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='MOM  Loan Application' datatype='real' name='[Calculation_183803219464114193]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_183803219458863108]-[Calculation_183803219461976080])/[Calculation_183803219461976080]' />
      </column>
      <column caption='Total Funded Amount' datatype='integer' name='[Calculation_183803219465179154]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([loan_amount])' />
      </column>
      <column caption='MTD Funded Amount' datatype='integer' name='[Calculation_183803219466596371]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF&#13;&#10;DATEDIFF(&apos;month&apos;,[issue_date],{MAX([issue_date])})=0&#13;&#10;THEN&#13;&#10;[loan_amount]&#13;&#10;END)' />
      </column>
      <column caption='PMTD Funded  Amnt' datatype='integer' name='[Calculation_183803219467477012]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF&#13;&#10;DATEDIFF(&apos;month&apos;,[issue_date], {MAX([issue_date])})=1&#13;&#10;THEN&#13;&#10;[loan_amount]&#13;&#10;END)' />
      </column>
      <column caption='MoM Funded Amount' datatype='real' name='[Calculation_183803219467943957]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_183803219466596371]-[Calculation_183803219467477012])/[Calculation_183803219467477012]' />
      </column>
      <column caption='Total Amount Received' datatype='integer' name='[Calculation_183803219468767254]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_payment])' />
      </column>
      <column caption='MTD Amount Received' datatype='integer' name='[Calculation_183803219469590551]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF &#13;&#10;DATEDIFF(&apos;month&apos;,[issue_date],{MAX([issue_date])}) =0&#13;&#10;THEN&#13;&#10;[total_payment]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='PMTD Amount Received' datatype='integer' name='[Calculation_183803219481808920]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF &#13;&#10;DATEDIFF(&apos;month&apos;, [issue_date],{MAX([issue_date])})=1&#13;&#10;THEN&#13;&#10;[total_payment]&#13;&#10;END)' />
      </column>
      <column caption='MTD Avg Int Rate' datatype='real' name='[Calculation_260645888166502401]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;IF &#13;&#10;DATEDIFF(&apos;month&apos;,[issue_date],{MAX([issue_date])})=0&#13;&#10;THEN&#13;&#10;[int_rate]&#13;&#10;END)' />
      </column>
      <column caption='PMTD Int Avg Rate' datatype='real' name='[Calculation_260645888168456195]' role='measure' type='quantitative'>
